# Django Settings
SECRET_KEY=your-secret-key-here-generate-with-python-secrets
DEBUG=False
ALLOWED_HOSTS=clinic.yourdomain.com,www.clinic.yourdomain.com

# CORS (comma-separated URLs, leave empty if not using API from other domains)
CORS_ORIGINS=

# Database (PostgreSQL)
DB_NAME=kumiclinic
DB_USER=clinic_user
DB_PASSWORD=strong-database-password
DB_HOST=localhost
DB_PORT=5432
DB_SSL=False

# Security (set to True in production)
SECURE_SSL_REDIRECT=False

# Email (for password reset)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
